# Dockerfile — "рецепт" образа с нашим приложением.

# Берём готовый образ с Python 3.12 (стабильная версия; не системный 3.14).
# "slim" — облегчённый вариант: меньше лишнего, образ компактнее.
FROM python:3.12-slim

# Переменные окружения для Python внутри контейнера:
#  - PYTHONDONTWRITEBYTECODE=1 — не создавать файлы .pyc (нам в контейнере не нужны)
#  - PYTHONUNBUFFERED=1        — не буферизовать вывод, чтобы логи Django сразу было видно
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Рабочая папка внутри контейнера. Все команды дальше выполняются относительно неё.
WORKDIR /app

# Сначала копируем ТОЛЬКО список зависимостей и ставим их.
# Это трюк с кэшем: пока requirements.txt не меняется, Docker не пересобирает
# этот слой заново при каждой сборке — экономит кучу времени.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Теперь копируем весь остальной код проекта.
COPY . .
