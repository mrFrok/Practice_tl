# Что НЕ копировать внутрь образа (аналог .gitignore, но для Docker).
# Чем меньше лишнего попадает в образ — тем он легче и тем меньше рискуем
# затащить туда секреты или мусор.

__pycache__/
*.pyc
*.pyo

.git/
.gitignore

.venv/
venv/
env/

.env            # файл с паролями/настройками — внутрь образа не кладём

*.sqlite3       # локальная БД, если вдруг появится
node_modules/   # пригодится в Фазе 2 (React)
