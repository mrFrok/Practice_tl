# Шаблон переменных окружения. Скопируй в .env и подставь свои значения:
#   cp .env.example .env
SECRET_KEY=замени-на-случайный-длинный-ключ
DEBUG=True

POSTGRES_DB=travelline
POSTGRES_USER=travelline
POSTGRES_PASSWORD=замени-на-свой-пароль

# Демо-админ для /admin (создаётся при первом старте). Только для учебного проекта.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
